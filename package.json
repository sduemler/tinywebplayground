{
  "name": "tinywebplayground",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "download-posters": "node scripts/download-preset-posters.mjs",
    "build-life-tables": "node scripts/build-life-tables.mjs",
    "build-crossword": "node scripts/build-layout.mjs --shape cat",
    "preview-crossword": "node scripts/preview-puzzle.mjs",
    "export-crossword": "node scripts/export-puzzle.mjs",
    "set-launch": "node scripts/set-launch.mjs",
    "gen-clues": "node --env-file=.env scripts/gen-clues.mjs",
    "gen-clues:finalize": "node --env-file=.env scripts/gen-clues.mjs --finalize",
    "gen-clues:finalize-shuffled": "node --env-file=.env scripts/gen-clues.mjs --finalize --shuffle"
  },
  "dependencies": {
    "@astrojs/netlify": "^6.0.0",
    "@astrojs/react": "^4.4.2",
    "@types/d3-force": "^3.0.10",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "astro": "^5.16.10",
    "d3-force": "^3.0.0",
    "firebase": "^12.13.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tone": "^15.1.22",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "canvas": "^3.2.3",
    "firebase-admin": "^12.7.0"
  }
}
