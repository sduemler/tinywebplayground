---
export const prerender = true;
import ProjectLayout from "@layouts/ProjectLayout.astro";
import { projects } from "@data/projects";
import CrosswordArchive from "@components/projects/the-crossword/CrosswordArchive";

const project = projects.find((p) => p.slug === "the-crossword")!;
---

<ProjectLayout
  project={project}
  subtitle="Past puzzles — relive how the community solved them."
>
  <CrosswordArchive client:load />
</ProjectLayout>
