---
import BaseLayout from './BaseLayout.astro';
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  subtitle?: string;
}

const { project, subtitle } = Astro.props;
---

<BaseLayout title={`${project.title} — tinywebplayground`}>
  <div class="project-wrapper" style={`--accent: ${project.accentColor};`}>
    <header class="project-header">
      <a href="/" class="back-link" aria-label="Back to hub">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M12 4l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Back
      </a>
      {project.titleHtml ? (
        <span class="project-title" set:html={project.titleHtml} />
      ) : (
        <span class="project-title">{project.title}</span>
      )}
      {subtitle && <span class="project-subtitle">{subtitle}</span>}
    </header>
    <main class="project-content">
      <slot />
    </main>
  </div>
</BaseLayout>

<style>
  .project-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .project-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1.5rem;
    border-bottom: 2px solid var(--color-border);
    background: var(--color-surface);
    min-height: 0;
  }

  .back-link {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--color-muted);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: color var(--transition);
  }

  .back-link:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .project-title {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-muted);
  }

  .project-subtitle {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--color-muted);
    opacity: 0.7;
    margin-left: auto;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 700px) {
    .project-subtitle {
      display: none;
    }
  }

  @media (max-width: 600px) {
    .project-header {
      padding: 0.6rem 0.75rem;
      gap: 0.5rem;
    }

    .back-link {
      font-size: 0.8rem;
    }

    .project-title {
      font-size: 0.9rem;
    }
  }

  .project-content {
    flex: 1;
    padding: 2rem 1.5rem;
  }

  @media (max-width: 480px) {
    .project-content {
      padding: 1.25rem 0.75rem;
    }
  }
</style>
