---
export const prerender = true;
import ProjectLayout from "@layouts/ProjectLayout.astro";
import { projects } from "@data/projects";
import TypingTerror from "../../components/projects/typing-terror/TypingTerror";

const project = projects.find((p) => p.slug === "typing-terror")!;
---

<ProjectLayout project={project}>
  <TypingTerror client:load />

  <footer class="site-footer">
    <span>© 2026 sduemler</span>
    <a
      href="https://github.com/sduemler"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="GitHub"
      class="footer-github"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path
          d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"
        ></path>
      </svg>
    </a>
  </footer>
</ProjectLayout>

<style>
  .site-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1.25rem 1.5rem;
    margin-top: 2rem;
    background: var(--color-accent-light);
    border-top: 2px solid var(--color-border);
    font-size: 0.875rem;
    color: var(--color-muted);
    font-family: var(--font-body);
  }

  .footer-github {
    display: flex;
    align-items: center;
    color: var(--color-muted);
    transition: color var(--transition);
  }

  .footer-github:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
</style>

<!-- Aged-parchment + blood-red palette, scoped to this project only. The typing
     stage darkens further toward black/red across the three prompts (see
     TypingTerror.module.css); this just sets the calm tier-1 baseline. -->
<style is:global>
  body {
    background-color: #f2e8cf;
  }

  .project-wrapper {
    --color-bg: #f2e8cf;
    --color-text: #2b211a;
    --color-muted: #7a6a55;
    --color-surface: #f7efd8;
    --color-border: #d8c7a0;
    --color-accent: #a01b1b;
    --color-accent-light: #ecdcc0;
    --color-rich: #3a1414;
    --color-rich-text: #f7efd8;
  }
</style>
