---
export const prerender = true;
import ProjectLayout from "@layouts/ProjectLayout.astro";
import { projects } from "@data/projects";
import TheCrossword from "@components/projects/the-crossword/TheCrossword";

const project = projects.find((p) => p.slug === "the-crossword")!;
---

<ProjectLayout project={project}>
  <TheCrossword client:load />
</ProjectLayout>
