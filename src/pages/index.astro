---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
---

<BaseLayout title="tinywebplayground">
    <div class="page">
        <header class="site-header">
            <h1 class="site-title">
                <span class="t-drop">t</span><span class="middle-letters"
                    >inywebplaygroun</span
                ><span class="t-drop">d</span>
            </h1>
        </header>

        <main class="hub">
            <div class="grid">
                {projects.map((project) => <ProjectCard project={project} />)}
            </div>
        </main>

        <section class="subscribe">
            <h2 class="subscribe-title">Stay in the loop</h2>
            <p class="subscribe-desc">
                Get notified when new projects are added.
            </p>
            <form class="subscribe-form" id="subscribe-form">
                <input
                    type="email"
                    class="subscribe-input"
                    placeholder="your@email.com"
                    required
                    aria-label="Email address"
                    id="subscribe-email"
                />
                <button type="submit" class="subscribe-btn" id="subscribe-btn"
                    >Subscribe</button
                >
            </form>
            <p class="subscribe-msg" id="subscribe-msg" aria-live="polite"></p>
        </section>

        <footer class="site-footer">
            <span>© 2026 sduemler</span>
            <a
                href="https://github.com/sduemler"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="GitHub"
                class="footer-github"
            >
                <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                >
                    <path
                        d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"
                    ></path>
                </svg>
            </a>
        </footer>
    </div>
</BaseLayout>

<style>
    .page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    .site-header {
        text-align: center;
        padding: 3rem 1.5rem 2rem;
    }

    .site-title {
        font-family: var(--font-display);
        font-size: 2.8rem;
        font-weight: 400;
        margin: 0;
        color: var(--color-text);
        line-height: 1;
        letter-spacing: -0.01em;
    }

    .t-drop {
        font-size: 5.2rem;
        line-height: 0.75;
        display: inline-block;
        vertical-align: -0.15em;
        color: var(--color-accent);
    }

    .middle-letters {
        text-decoration: underline;
        text-decoration-color: var(--color-accent);
        text-decoration-thickness: 3px;
        text-underline-offset: 4px;
    }

    .hub {
        flex: 1;
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 1.5rem 3rem;
        width: 100%;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }

    .site-footer {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        padding: 1.25rem 1.5rem;
        background: var(--color-accent-light);
        border-top: 2px solid var(--color-border);
        font-size: 0.875rem;
        color: var(--color-muted);
        font-family: var(--font-body);
    }

    .footer-github {
        display: flex;
        align-items: center;
        color: var(--color-muted);
        transition: color var(--transition);
    }

    .footer-github:hover {
        color: var(--color-accent);
        text-decoration: none;
    }

    .subscribe {
        max-width: 480px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem;
        text-align: center;
    }

    .subscribe-title {
        font-family: var(--font-display);
        font-size: 1.5rem;
        font-weight: 400;
        color: var(--color-text);
        margin: 0 0 0.25rem;
    }

    .subscribe-desc {
        color: var(--color-muted);
        font-size: 0.95rem;
        margin: 0 0 1rem;
    }

    .subscribe-form {
        display: flex;
        gap: 0.5rem;
    }

    .subscribe-input {
        flex: 1;
        padding: 0.6rem 0.9rem;
        border: 2px solid var(--color-border);
        border-radius: var(--radius);
        background: var(--color-surface);
        color: var(--color-text);
        font-family: var(--font-body);
        font-size: 0.95rem;
        outline: none;
        transition: border-color var(--transition);
    }

    .subscribe-input:focus {
        border-color: var(--color-accent);
    }

    .subscribe-input::placeholder {
        color: var(--color-muted);
        opacity: 0.6;
    }

    .subscribe-btn {
        padding: 0.6rem 1.2rem;
        border: none;
        border-radius: var(--radius);
        background: var(--color-accent);
        color: var(--color-rich-text);
        font-family: var(--font-display);
        font-size: 0.95rem;
        font-weight: 400;
        cursor: pointer;
        transition:
            background var(--transition),
            transform var(--transition);
        white-space: nowrap;
    }

    .subscribe-btn:hover {
        background: var(--color-rich);
        transform: translateY(-1px);
    }

    .subscribe-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
    }

    .subscribe-btn.success {
        background: #5a7a3a;
        opacity: 1;
        cursor: default;
        pointer-events: none;
        animation: pop 400ms cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @keyframes pop {
        0% { transform: scale(1); }
        50% { transform: scale(1.25); }
        100% { transform: scale(1); }
    }

    .subscribe-input:disabled {
        opacity: 0.7;
        cursor: default;
    }

    .subscribe-msg {
        font-size: 0.85rem;
        margin: 0.75rem 0 0;
        min-height: 1.3em;
    }

    .subscribe-msg.success {
        color: #5a7a3a;
    }

    .subscribe-msg.error {
        color: #b04a2e;
    }

    @media (max-width: 900px) {
        .grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 560px) {
        .site-title {
            font-size: 2rem;
        }

        .t-drop {
            font-size: 3.8rem;
        }

        .middle-letters {
            text-decoration-thickness: 2px;
        }

        .grid {
            grid-template-columns: 1fr;
        }

        .subscribe-form {
            flex-direction: column;
        }
    }
</style>

<script>
    const form = document.getElementById("subscribe-form") as HTMLFormElement;
    const input = document.getElementById(
        "subscribe-email",
    ) as HTMLInputElement;
    const btn = document.getElementById("subscribe-btn") as HTMLButtonElement;
    const msg = document.getElementById(
        "subscribe-msg",
    ) as HTMLParagraphElement;

    form.addEventListener("submit", async (e) => {
        e.preventDefault();
        btn.disabled = true;
        msg.textContent = "";
        msg.className = "subscribe-msg";

        try {
            const res = await fetch("/api/subscribe", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ email: input.value.trim() }),
            });
            const data = await res.json();

            if (data.success) {
                msg.textContent =
                    "You're subscribed! Check your email to confirm.";
                msg.classList.add("success");
                input.disabled = true;
                btn.disabled = true;
                btn.innerHTML = "👍";
                btn.classList.add("success");
                return;
            } else {
                msg.textContent = data.error || "Something went wrong.";
                msg.classList.add("error");
            }
        } catch {
            msg.textContent = "Something went wrong. Please try again.";
            msg.classList.add("error");
        } finally {
            btn.disabled = false;
        }
    });
</script>
